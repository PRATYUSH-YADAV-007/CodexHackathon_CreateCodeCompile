# Copy this file to .env.local and replace the value with your OpenAI API key.
OPENAI_API_KEY=your_openai_api_key_here
# Production: URL of your isolated Java runner (container/VM sandbox).
EXECUTION_SERVICE_URL=
# Optional development override. Local execution is enabled by default in development.
# Set to false to disable it. This is ignored in production, where an isolated service is required.
ALLOW_LOCAL_JAVA_EXECUTION=true
